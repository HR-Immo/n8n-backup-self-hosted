    {
      "id": "c3866df3-ce4b-4a85-9bea-ddf7304fc120",
      "name": "Lookup file",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1856,
        128
      ],
      "parameters": {
        "jsCode": "// Verarbeitet alle Items und prueft fuer jedes ob die Backup-Datei in GitHub existiert.\n// $input.all() statt $input.item, damit alle N Workflows erhalten bleiben.\nconst fileIndex = $('Build file index').first().json.fileIndex ?? {};\nconst results = [];\n\nfor (const item of $input.all()) {\n  const fileName = item.json.fileName;\n  const sha = fileIndex[fileName] ?? null;\n\n  results.push({\n    json: {\n      ...item.json,\n      sha,\n      fileExists: sha !== null,\n    }\n  });\n}\n\nreturn results;"
      }
    },
