    {
      "id": "fced72e2-039d-427b-b414-5542aec644d5",
      "name": "Build file index",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        784,
        128
      ],
      "parameters": {
        "jsCode": "// Build lookup map { filename: sha } from all GitHub repo files.\n// Root files: name = filename only (e.g. \"my-workflow-tag.json\")\n// Archiviert files: name was mapped to path by Edit Fields (e.g. \"archiviert/my-workflow-tag.json\")\nconst files = $input.all();\nconst fileIndex = {};\nfor (const item of files) {\n  const name = item.json.name;\n  const sha = item.json.sha;\n  if (name && sha) {\n    fileIndex[name] = sha;\n  }\n}\nreturn [{ json: { fileIndex } }];"
      }
    },
    {
      "id": "c1a0e279-3aa7-4cc1-b8e4-28b5dddfb829",
      "name": "Retrieve workflows",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.3,
      "position": [
        1008,
        128
      ],
      "parameters": {
        "url": "https://n8n.hoewer-roth-immobilien.de/api/v1/workflows",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "n8nApi",
        "options": {}
      },
      "credentials": {
        "n8nApi": {
          "id": "00fSEH7hxMawsVzn",
          "name": "n8n account"
        }
      }
    },
    {
      "id": "661c291f-d674-4035-9516-07edef784dc0",
      "name": "Code in JavaScript",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1168,
        128
      ],
      "parameters": {
        "jsCode": "const workflows = $json.data ?? [];\n\nreturn workflows.map((wf) => {\n  const isArchived = wf.isArchived === true;\n\n  return {\n    json: {\n      name: isArchived ? `Archiviert/${wf.name}` : wf.name,\n      nodes: wf.nodes ?? [],\n      connections: wf.connections ?? {},\n      settings: wf.settings ?? { executionOrder: 'v1' },\n      pinData: wf.pinData ?? undefined,\n      staticData: wf.staticData ?? null,\n      meta: wf.meta ?? {},\n      tags: wf.tags ?? [],\n      __backupMeta: {\n        archived: isArchived,\n        active: wf.active === true,\n        workflowId: wf.id,\n      },\n    },\n  };\n});"
      }
    },
