        1200,
        304
      ],
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const senderEmail = ($('Sprachnotiz empfangen').first().json.query?.sender ?? '').toLowerCase();\nconst users = $input.all();\n\nconst match = users.find(u =>\n  u.json.type === 'person' &&\n  u.json.person?.email?.toLowerCase() === senderEmail\n);\n\nreturn [{\n  json: {\n    notionUserId: match?.json.id ?? null,\n    senderName: match?.json.name ?? senderEmail\n  }\n}];"
      }
    },
